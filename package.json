{
  "name": "service-butler-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:start": "npx supabase start",
    "db:reset": "npx supabase db reset",
    "db:push": "npx supabase db push",
    "db:seed": "node scripts/seed-users.mjs && npx supabase db seed",
    "db:validate": "echo 'Run: psql \"$SUPABASE_DB_URL\" -f scripts/validate-db.sql'",
    "inngest:dev": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.5",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.8",
    "inngest": "^3.30.1",
    "next": "^15.2.0",
    "postmark": "^4.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^18.1.1",
    "twilio": "^5.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.2.0",
    "typescript": "^5.7.2"
  }
}
